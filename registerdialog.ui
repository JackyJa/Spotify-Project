  <property name="styleSheet">
   <string notr="true">RegisterDialog {
    background-color: #050505;
    background-image: qradialgradient(
        cx:0.2, cy:0.9, radius: 1.5, fx:0.2, fy:0.9,
        stop:0 rgba(29, 185, 84, 80), 
        stop:0.3 #050505, 
        stop:1 #000000
    );
}
QLabel { color: #FFFFFF; font-weight: bold; background: transparent; }
#titleLabel { color: #1DB954; font-size: 24px; font-weight: 900; }
#photoPreviewLabel { color: #535353; border: 2px dashed #535353; border-radius: 50px; background: transparent; }

QLineEdit, QComboBox {
    background-color: rgba(255, 255, 255, 0.05);
    color: #FFFFFF;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 10px;
    padding: 10px;
    font-size: 14px;
}
QLineEdit:focus, QComboBox:focus { border: 1px solid #1DB954; }

QPushButton {
    background-color: rgba(255, 255, 255, 0.05);
    color: #FFFFFF;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 15px;
    padding: 10px;
    font-weight: bold;
}
QPushButton:hover { background-color: rgba(29, 185, 84, 0.1); border: 1px solid #1DB954; color: #1DB954; }


QPushButton#signupButton {
    background-color: #1DB954;
    color: #000000;
    border: none;
    border-radius: 20px;
    padding: 12px;
}
QPushButton#signupButton:hover { background-color: #1ed760; }


QPushButton#btnSelectPhoto {
    background-color: rgba(255, 255, 255, 0.05);
    color: #B3B3B3;
    border: 1px solid rgba(255, 255, 255, 0.1);
}
QPushButton#btnSelectPhoto:hover { border: 1px solid #1DB954; color: #1DB954; }


QComboBox::drop-down { border: none; }
QComboBox QAbstractItemView { background-color: #282828; color: #FFFFFF; selection-background-color: #1DB954; border: 1px solid #535353; }</string>
